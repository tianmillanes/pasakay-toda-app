rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      // Allow user to write to their own doc, OR allow admin to write
      allow write: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    match /user_verifications/{userId} {
      // FIX: Allow user to read/write their own verification data, OR admin
      allow read: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow write: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // Rides collection
    match /rides/{rideId} {
      allow read: if request.auth != null;
      
      // Allow create for any authenticated user
      allow create: if request.auth != null;
      
      // Allow update if:
      // 1. User is the driver (current or incoming)
      // 2. User is the passenger (current or incoming)
      // 3. User is the assigned driver
      // 4. User is an admin
      allow update: if request.auth != null && (
        resource.data.driverId == request.auth.uid ||
        resource.data.passengerId == request.auth.uid ||
        resource.data.assignedDriverId == request.auth.uid ||
        request.resource.data.driverId == request.auth.uid ||
        request.resource.data.assignedDriverId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      
      // Allow delete only for admin or passenger
      allow delete: if request.auth != null && (
        resource.data.passengerId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    match /rides/{rideId}/{sub=**} {
      allow read, write: if request.auth != null;
    }

    // Notifications collection
    match /notifications/{notifId} {
      allow read, write: if request.auth != null;
    }

    // PasaBuy requests
    match /pasabuy_requests/{requestId} {
      allow read, write: if request.auth != null;
    }
    match /pasabuy_requests/{requestId}/{sub=**} {
      allow read, write: if request.auth != null;
    }

    // PasaBuy status logs
    match /pasabuy_status_logs/{logId} {
      allow read, create: if request.auth != null;
      allow update, delete: if false; // Logs should be write-once
    }

    // Barangays / Geofences
    match /barangays/{barangayId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /barangays/{barangayId}/{sub=**} {
      allow read, write: if request.auth != null;
    }

    // Driver queue
    match /driver_queue/{docId} {
      allow read, write: if request.auth != null;
    }

    // GCash QR
    match /gcash_qr/{docId} {
      allow read, write: if request.auth != null;
    }

    // Settings (fare rules, maintenance mode, etc.)
    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /settings/{docId}/{sub=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // System settings & Queues
    match /system/{docId} {
      allow read, write: if request.auth != null;
    }
    // FIX: Allow recursive access to system sub-paths (necessary for queues)
    match /system/{docId}/{sub=**} {
      allow read, write: if request.auth != null;
    }

    // Catch-all fallback - deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
