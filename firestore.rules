rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      // Allow user to write to their own doc, OR allow admin to write
      allow write: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    match /user_verifications/{userId} {
      // Admin can read/write everything. User can only write/delete their own verification data.
      allow read: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow write: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // Rides collection
    match /rides/{rideId} {
      allow read, write: if request.auth != null;
    }

    // Notifications collection
    match /notifications/{notifId} {
      allow read, write: if request.auth != null;
    }

    // PasaBuy requests
    match /pasabuy_requests/{requestId} {
      allow read, write: if request.auth != null;
    }

    // Barangays / Geofences
    match /barangays/{barangayId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /barangays/{barangayId}/{sub=**} {
      allow read, write: if request.auth != null;
    }

    // Driver queue
    match /driver_queue/{docId} {
      allow read, write: if request.auth != null;
    }

    // GCash QR
    match /gcash_qr/{docId} {
      allow read, write: if request.auth != null;
    }

    // Settings (fare rules, maintenance mode, etc.)
    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /settings/{docId}/{sub=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // System settings
    match /system/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Catch-all fallback - deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
