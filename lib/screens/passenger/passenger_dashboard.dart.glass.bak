                                ),
                              ),
                            ),
                            const SizedBox(height: 24),
                            // User Name
                            Text(
                              '${user?.name.split(' ')[0] ?? 'Passenger'}',
                              style: const TextStyle(
                                fontSize: 36,
                                fontWeight: FontWeight.w900,
                                color: Color(0xFF1A1D29),
                                letterSpacing: -1.0,
                                height: 1.1,
