import 'package:Pasakay/screens/passenger/active_ride_screen.dart';
import 'package:flutter/material.dart';
import 'dart:async';
import '../../models/lat_lng.dart';
import 'package:provider/provider.dart';
import 'package:cloud_firestore/cloud_firestore.dart';
import 'package:geolocator/geolocator.dart';
import '../../services/location_service.dart';
import '../../services/firestore_service.dart';
import '../../services/auth_service.dart';
import '../../services/fare_service.dart';
import '../../services/address_search_service.dart';
import '../../models/ride_model.dart';
import '../../widgets/usability_helpers.dart';
import '../../widgets/location_helpers.dart';
import 'map_picker_screen.dart';
import '../../utils/app_theme.dart';
import 'dart:math';

class BookRideScreen extends StatefulWidget {
  final LatLng? initialPickupLocation;
  final String? initialPickupAddress;
  final LatLng? initialDropoffLocation;
  final String? initialDropoffAddress;

  const BookRideScreen({
    super.key,
    this.initialPickupLocation,
    this.initialPickupAddress,
    this.initialDropoffLocation,
    this.initialDropoffAddress,
  });

  @override
  State<BookRideScreen> createState() => _BookRideScreenState();
}

class _BookRideScreenState extends State<BookRideScreen> {
  LatLng? _pickupLocation, _dropoffLocation, _currentLocation;
  String _pickupAddress = '',
      _dropoffAddress = '',
      _currentLocationAddress = '';
  double? _estimatedFare, _distance;
  int? _estimatedDuration;
  int _passengerCount = 1; // Number of passengers (1-4)
  bool _isLoadingFare = false,
      _isBooking = false,
      _showPickupSuggestions = false;
  bool _showDestinationSuggestions = false, _isSearching = false;
  List<Map<String, dynamic>> _recentPickups = [],
      _recentDestinations = [],
      _searchResults = [];

  final _pickupController = TextEditingController(),
      _dropoffController = TextEditingController(),
      _descriptionController = TextEditingController();
  final _pickupFocusNode = FocusNode(), _dropoffFocusNode = FocusNode();
  Timer? _debounceTimer;

  @override
  void dispose() {
    _debounceTimer?.cancel();
    _pickupController.dispose();
    _dropoffController.dispose();
    _descriptionController.dispose();
    _pickupFocusNode.dispose();
    _dropoffFocusNode.dispose();
    super.dispose();
  }

  @override
  void initState() {
    super.initState();
    _initializeLocations();
    _getCurrentLocation();
    _loadRecentLocations();
    _pickupController.addListener(() {
      if (_pickupController.text.isEmpty) {
        if (mounted) setState(() => _searchResults = []);
      } else {
        // When searching for pickup, prioritize current location
        _performSearch(_pickupController.text, proximity: _currentLocation);
      }
    });

    _dropoffController.addListener(() {
      if (_dropoffController.text.isEmpty) {
        if (mounted) setState(() => _searchResults = []);
      } else {
        // When searching for dropoff, prioritize pickup location if set, otherwise current location
        // This mimics Google Maps behavior where destination search is relative to origin
        _performSearch(
          _dropoffController.text, 
          proximity: _pickupLocation ?? _currentLocation
        );
      }
    });
  }

  void _initializeLocations() {
    // Pre-fill pickup location if provided
    if (widget.initialPickupLocation != null && widget.initialPickupAddress != null) {
      _pickupLocation = widget.initialPickupLocation;
      _pickupAddress = widget.initialPickupAddress!;
      _pickupController.text = widget.initialPickupAddress!;

    }

    // Pre-fill dropoff location if provided
    if (widget.initialDropoffLocation != null && widget.initialDropoffAddress != null) {
      _dropoffLocation = widget.initialDropoffLocation;
      _dropoffAddress = widget.initialDropoffAddress!;
      _dropoffController.text = widget.initialDropoffAddress!;

      
      // Calculate fare if both locations are provided
      if (_pickupLocation != null) {
        Future.delayed(const Duration(milliseconds: 500), () {
          if (mounted) _calculateFareAndETA();
        });
      }
    }
  }

  Future<void> _performSearch(String query, {LatLng? proximity}) async {
    _debounceTimer?.cancel();
    if (query.length < 2) {
      if (mounted) setState(() => _searchResults = []);
      return;
    }
    
    _debounceTimer = Timer(const Duration(milliseconds: 500), () async {
      if (!mounted) return;
      setState(() => _isSearching = true);
      try {
        final results = await AddressSearchService.searchAddresses(
          query,
          proximity: proximity ?? _currentLocation,
        );
        if (mounted) {
          setState(() {
            _searchResults = results
                .map(
                  (r) => {
                    'address': r.address,
                    'description': r.description,
                    'coordinates': r.coordinates,
                  },
                )
                .toList();
            _isSearching = false;
          });
        }
      } catch (e) {
        if (mounted) {
          setState(() {
            _searchResults = [];
            _isSearching = false;
          });
        }
      }
    });
  }

  Future<void> _openMapPicker(bool isForPickup) async {
    final result = await Navigator.push<Map<String, dynamic>>(
      context,
      MaterialPageRoute(
        builder: (context) => MapPickerScreen(
          isForPickup: isForPickup,
          initialLocation: (isForPickup ? _pickupLocation : _dropoffLocation) ?? _currentLocation,
        ),
      ),
    );
    if (result != null && mounted) {
      final address = result['address'] as String,
          location = result['location'] as LatLng;
      setState(() {
        if (isForPickup) {
          _pickupController.text = address;
          _pickupAddress = address;
          _pickupLocation = location;
        } else {
          _dropoffController.text = address;
          _dropoffAddress = address;
          _dropoffLocation = location;
        }
      });
      if (_pickupLocation != null && _dropoffLocation != null)
        _calculateFareAndETA();
    }
  }

  Future<void> _getCurrentLocation() async {
    try {
      final locationService = Provider.of<LocationService>(
        context,
        listen: false,
      );
      final position = await locationService.getCurrentLocation();
      if (position != null && mounted) {
        final latLng = LatLng(position.latitude, position.longitude);
        final address = await locationService.getAddressFromCoordinates(
          position.latitude,
          position.longitude,
        );
        setState(() {
          _currentLocation = latLng;
          _currentLocationAddress = address;
        });
      }
    } on LocationServiceException catch (_) {
      if (mounted) {
        LocationHelpers.showLocationDisabledDialog(context);
      }
    } on LocationPermissionException catch (e) {
      if (mounted) {
        _showPermissionDeniedDialog(e.toString());
      }
    } catch (e) {
      if (mounted) {
        SnackbarHelper.showError(context, 'Could not get current location: $e');
      }
    }
  }

  void _showPermissionDeniedDialog(String message) {
    showDialog(
      context: context,
      barrierDismissible: false,
      builder: (context) => AlertDialog(
        title: Row(
          children: [
            const Icon(Icons.location_disabled, color: Colors.orange, size: 24),
            const SizedBox(width: 8),
            const Text('Location Permission Required'),
          ],
        ),
        content: Text(message),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(context),
            child: const Text('Cancel'),
          ),
          ElevatedButton(
            onPressed: () async {
              Navigator.pop(context);
              // Open app settings
              await Geolocator.openAppSettings();
            },
            style: ElevatedButton.styleFrom(
              backgroundColor: const Color(0xFF2D2D2D),
              foregroundColor: Colors.white,
            ),
            child: const Text('Open Settings'),
          ),
        ],
      ),
    );
  }

  Future<void> _loadRecentLocations() async {
    try {
      final authService = Provider.of<AuthService>(context, listen: false);
      final ridesSnapshot = await FirebaseFirestore.instance
          .collection('rides')
          .where('passengerId', isEqualTo: authService.currentUser!.uid)
          .where(
            'status',
            isEqualTo: RideStatus.completed.toString().split('.').last,
          )
          .orderBy('requestedAt', descending: true)
          .limit(10)
          .get();

      Map<String, Map<String, dynamic>> pickupMap = {}, destinationMap = {};
      for (var doc in ridesSnapshot.docs) {
        final data = doc.data();
        final pickupAddr = data['pickupAddress'] as String?,
            dropoffAddr = data['dropoffAddress'] as String?;
        final pickupLoc = data['pickupLocation'] as GeoPoint?,
            dropoffLoc = data['dropoffLocation'] as GeoPoint?;
        if (pickupAddr != null &&
            pickupLoc != null &&
            !pickupMap.containsKey(pickupAddr)) {
          pickupMap[pickupAddr] = {
            'address': pickupAddr,
            'location': LatLng(pickupLoc.latitude, pickupLoc.longitude),
          };
        }
        if (dropoffAddr != null &&
            dropoffLoc != null &&
            !destinationMap.containsKey(dropoffAddr)) {
          destinationMap[dropoffAddr] = {
            'address': dropoffAddr,
            'location': LatLng(dropoffLoc.latitude, dropoffLoc.longitude),
          };
        }
      }
      if (mounted)
        setState(() {
          _recentPickups = pickupMap.values.toList();
          _recentDestinations = destinationMap.values.toList();
        });
    } catch (e) {
      debugPrint('Error loading recent locations: $e');
    }
  }

  Future<void> _calculateFareAndETA() async {
    if (_pickupLocation == null || _dropoffLocation == null) return;
    setState(() => _isLoadingFare = true);
    try {
      final result = await FareService.calculateFareAndETA(
        pickupLat: _pickupLocation!.latitude,
        pickupLng: _pickupLocation!.longitude,
        dropoffLat: _dropoffLocation!.latitude,
        dropoffLng: _dropoffLocation!.longitude,
      );
      
      // Calculate fare: Base fare (₱20 for first 2km + ₱10/500m) + ₱20 per additional passenger
      // Formula: Base Fare (from FareService) + ((Passenger Count - 1) × ₱20)
      double baseFare = result['fare'] as double;
      const double additionalPassengerFee = 20.0;
      
      double extraPassengersFare = (_passengerCount - 1) * additionalPassengerFee;
      
      double adjustedFare = baseFare + extraPassengersFare;
      
      setState(() {
        _estimatedFare = adjustedFare;
        _estimatedDuration = result['duration'] as int;
        _distance = result['distance'] as double;
        _isLoadingFare = false;
      });
    } catch (e) {
      if (mounted) {
        setState(() => _isLoadingFare = false);
        SnackbarHelper.showError(context, 'Error calculating fare: $e');
      }
    }
  }

  Future<void> _bookRide() async {
    if (_pickupLocation == null ||
        _dropoffLocation == null ||
        _estimatedFare == null)
      return;

    // Set loading state IMMEDIATELY for instant user feedback
    setState(() => _isBooking = true);

    final locationService = Provider.of<LocationService>(
      context,
      listen: false,
    );

    // PASSENGER CAN BOOK FROM ANYWHERE - No location restrictions
    // The system will route to drivers based on pickup location's barangay

    // Check if widget is still mounted
    if (!mounted) {
      setState(() => _isBooking = false);
      return;
    }

    // Store references BEFORE async operations
    final navigator = Navigator.of(context);

    try {
      final authService = Provider.of<AuthService>(context, listen: false);
      final firestoreService = Provider.of<FirestoreService>(
        context,
        listen: false,
      );
      print('🚕 [BookRide] Creating ride...');
      print('   Passenger: ${authService.currentUser!.uid}');
      print('   From: $_pickupAddress');
      print('   To: $_dropoffAddress');
      print('   Fare: ₱$_estimatedFare');
      
      final ride = RideModel(
        id: '',
        passengerId: authService.currentUser!.uid,
        pickupLocation: GeoPoint(
          _pickupLocation!.latitude,
          _pickupLocation!.longitude,
        ),
        dropoffLocation: GeoPoint(
          _dropoffLocation!.latitude,
          _dropoffLocation!.longitude,
        ),
        pickupAddress: _pickupAddress,
        dropoffAddress: _dropoffAddress,
        fare: _estimatedFare!,
        estimatedDuration: _estimatedDuration ?? 0,
        requestedAt: DateTime.now(),
        // NOTE: barangayId will be determined by pickup location in firestore_service
        barangayId: null, // Let system determine based on pickup location
        barangayName: null, // Let system determine based on pickup location
        passengerCount: _passengerCount,
        notes: _descriptionController.text.trim().isEmpty ? null : _descriptionController.text.trim(),
      );
      
      print('📞 [BookRide] Calling createRideWithDriverCheck...');
      
      final result = await firestoreService.createRideWithDriverCheck(ride);
      
      print('📋 [BookRide] Result received:');
      print('   success: ${result['success']}');
      print('   rideId: ${result['rideId']}');
      print('   driverAssigned: ${result['driverAssigned']}');
      print('   onlineDriverCount: ${result['onlineDriverCount']}');

      // 100% diagnostic: immediately analyze ride and queue state
      if (result['rideId'] != null) {
        final rideId = result['rideId'] as String;
        print('🩺 [BookRide] Running diagnoseRideAssignment for $rideId...');
        final diag = await firestoreService.diagnoseRideAssignment(rideId);
        print('🩺 [BookRide] diagnoseRideAssignment result: $diag');
      }
      
      if (mounted) {
        if (result['success'] == true) {
          final driverAssigned = result['driverAssigned'] ?? false;
          final onlineCount = result['onlineDriverCount'] ?? 0;
          
          print('✅ [BookRide] Ride booked successfully! Driver assigned: $driverAssigned');
          
          SnackbarHelper.showSuccess(
            context,
            driverAssigned
                ? 'Ride booked successfully! Driver assigned.'
                : 'Ride booked! Waiting driver to accept ($onlineCount online)...',
            seconds: 3,
          );
          
          // Navigate to ActiveRideScreen
          navigator.pushReplacement(
            MaterialPageRoute(
              builder: (context) => ActiveRideScreen(
                ride: RideModel(
                  id: result['rideId'],
                  passengerId: ride.passengerId,
                  pickupLocation: ride.pickupLocation,
                  dropoffLocation: ride.dropoffLocation,
                  pickupAddress: ride.pickupAddress,
                  dropoffAddress: ride.dropoffAddress,
                  fare: ride.fare,
                  estimatedDuration: ride.estimatedDuration,
                  requestedAt: ride.requestedAt,
                  barangayId: ride.barangayId,
                  barangayName: ride.barangayName,
                  passengerCount: ride.passengerCount,
                  notes: ride.notes,
                  isPasaBuy: ride.isPasaBuy,
                  itemDescription: ride.itemDescription,
                  driverId: driverAssigned ? result['driverId'] : null,
                  status: driverAssigned ? RideStatus.accepted : RideStatus.pending,
                ),
              ),
            ),
          );
        } else {
          SnackbarHelper.showError(
            context,
            result['error'] ?? 'Failed to book ride',
            seconds: 5,
          );
        }
      }
    } catch (e) {
      if (mounted) {
        SnackbarHelper.showError(
          context,
          'Error booking ride: $e',
          seconds: 4,
        );
      }
    } finally {
      if (mounted) setState(() => _isBooking = false);
    }
  }

  @override
  Widget build(BuildContext context) => Scaffold(
    backgroundColor: AppTheme.backgroundLight,
    appBar: AppBar(
      title: const Text(
        'Book a Ride',
        style: TextStyle(
          color: Color(0xFF1A1A1A),
          fontWeight: FontWeight.w700,
          fontSize: 17,
        ),
      ),
      backgroundColor: AppTheme.backgroundLight,
      elevation: 0,
      centerTitle: true,
      leading: IconButton(
        icon: const Icon(Icons.arrow_back_ios_new_rounded, color: Color(0xFF1A1A1A), size: 18),
        onPressed: () => Navigator.pop(context),
      ),
    ),
    body: Column(
      children: [
        // Top Location Section
        Container(
          width: double.infinity,
          color: AppTheme.backgroundLight,
          padding: const EdgeInsets.symmetric(horizontal: 20, vertical: 10),
          child: Column(
            children: [
              // Clean white container for inputs
              Container(
                decoration: BoxDecoration(
                  color: Colors.white,
                  borderRadius: BorderRadius.circular(16),
                  boxShadow: [
                    BoxShadow(
                      color: Colors.black.withOpacity(0.03),
                      blurRadius: 10,
                      offset: const Offset(0, 4),
                    ),
                  ],
                ),
                padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 8),
                child: IntrinsicHeight(
                  child: Row(
                    children: [
                      // Timeline
                      Padding(
                        padding: const EdgeInsets.symmetric(vertical: 16),
                        child: Column(
                          children: [
                            const Icon(Icons.circle, color: AppTheme.primaryGreen, size: 12),
                            const Spacer(),
                            const Icon(Icons.square, color: AppTheme.errorRed, size: 12),
                          ],
                        ),
                      ),
                      const SizedBox(width: 16),
                      // Inputs
                      Expanded(
                        child: Column(
                          children: [
                            _buildMinimalInput(true),
                            _buildMinimalInput(false),
                          ],
                        ),
                      ),
                    ],
                  ),
                ),
              ),
              
              if (_showPickupSuggestions || _showDestinationSuggestions)
                const SizedBox.shrink(),
            ],
          ),
        ),

        // Main Content Area
        Expanded(
          child: (_showPickupSuggestions || _showDestinationSuggestions)
              ? GestureDetector(
                  onTap: () {
                    FocusScope.of(context).unfocus();
                    setState(() {
                      _showPickupSuggestions = false;
                      _showDestinationSuggestions = false;
                    });
                  },
                  child: Container(
                    color: AppTheme.backgroundLight,
                    child: SingleChildScrollView(
                      padding: const EdgeInsets.symmetric(horizontal: 20),
                      child: Column(
                        children: [
                          const SizedBox(height: 12),
                          // Wrap in GestureDetector to prevent closing when tapping the list itself (if not hitting a tile)
                          GestureDetector(
                            onTap: () {},
                            child: _buildInlineSuggestions(),
                          ),
                          const SizedBox(height: 20),
                        ],
                      ),
                    ),
                  ),
                )
              : SingleChildScrollView(
                  padding: const EdgeInsets.all(24),
                  child: (_pickupLocation != null && _dropoffLocation != null)
                      ? _buildFormalRideDetails()
                      : _buildEmptyState(),
                ),
        ),
      ],
    ),
    bottomNavigationBar: (_pickupLocation != null && _dropoffLocation != null && !_showPickupSuggestions && !_showDestinationSuggestions)
        ? SafeArea(
            child: Container(
              padding: const EdgeInsets.fromLTRB(24, 0, 24, 24),
              child: ElevatedButton(
                onPressed: _isBooking ? null : _bookRide,
                style: ElevatedButton.styleFrom(
                  backgroundColor: AppTheme.primaryGreen,
                  foregroundColor: Colors.white,
                  padding: const EdgeInsets.symmetric(vertical: 18),
                  elevation: 0,
                  shape: RoundedRectangleBorder(
                    borderRadius: BorderRadius.circular(16),
                  ),
                  minimumSize: const Size(double.infinity, 56),
                ),
                child: _isBooking
                    ? const SizedBox(
                        width: 24,
                        height: 24,
                        child: CircularProgressIndicator(
                          color: Colors.white,
                          strokeWidth: 2,
                        ),
                      )
                    : const Text(
                        'Confirm Booking',
                        style: TextStyle(
                          fontSize: 16,
                          fontWeight: FontWeight.w700,
                        ),
                      ),
              ),
            ),
          )
        : null,
  );

  Widget _buildMinimalInput(bool isPickup) {
    final controller = isPickup ? _pickupController : _dropoffController;
    final focusNode = isPickup ? _pickupFocusNode : _dropoffFocusNode;
    final hint = isPickup ? 'Where from?' : 'Where to?';

    return TextField(
      controller: controller,
      focusNode: focusNode,
      style: const TextStyle(
        fontSize: 15,
        color: Color(0xFF1A1A1A),
        fontWeight: FontWeight.w500,
      ),
      decoration: InputDecoration(
        hintText: hint,
        hintStyle: TextStyle(
          fontSize: 15,
          color: Colors.grey.shade400,
          fontWeight: FontWeight.w400,
        ),
        border: InputBorder.none,
        isDense: true,
        contentPadding: const EdgeInsets.symmetric(vertical: 16),
        suffixIcon: IconButton(
          icon: Icon(Icons.map_outlined, size: 20, color: Colors.grey.shade400),
          onPressed: () => _openMapPicker(isPickup),
          padding: EdgeInsets.zero,
          constraints: const BoxConstraints(),
          visualDensity: VisualDensity.compact,
        ),
      ),
      onTap: () => setState(() {
        _showPickupSuggestions = isPickup;
        _showDestinationSuggestions = !isPickup;
      }),
    );
  }

  Widget _buildInlineSuggestions() {
    final isPickup = _showPickupSuggestions;
    final recents = isPickup ? _recentPickups : _recentDestinations;
    final currentQuery = isPickup ? _pickupController.text : _dropoffController.text;
    final showSearchResults = currentQuery.length >= 2 && _searchResults.isNotEmpty;

    return Container(
      decoration: BoxDecoration(
        color: Colors.white,
        borderRadius: BorderRadius.circular(20), // More rounded
        boxShadow: [
          BoxShadow(
            color: Colors.black.withOpacity(0.08), // Slightly stronger shadow
            blurRadius: 24,
            offset: const Offset(0, 8),
          ),
        ],
      ),
      constraints: BoxConstraints(
        maxHeight: MediaQuery.of(context).size.height * 0.5, // Taller list
      ),
      child: ClipRRect(
        borderRadius: BorderRadius.circular(20),
        child: ListView(
          padding: const EdgeInsets.symmetric(vertical: 8), // Vertical padding
          shrinkWrap: true,
          children: [
            if (_isSearching)
              const Padding(
                padding: EdgeInsets.all(32.0),
                child: Center(
                  child: SizedBox(
                    width: 24,
                    height: 24,
                    child: CircularProgressIndicator(
                      strokeWidth: 2.5,
                      valueColor: AlwaysStoppedAnimation<Color>(AppTheme.primaryGreen),
                    ),
                  ),
                ),
              )
            else if (showSearchResults) ...[
               _buildSectionHeader('SEARCH RESULTS'),
              ..._searchResults.take(10).map((result) => _buildSuggestionItem(
                address: result['address'],
                description: result['description'] ?? result['address'],
                coordinates: result['coordinates'],
                isPickup: isPickup,
                icon: Icons.location_on_outlined,
                iconColor: AppTheme.primaryGreen,
              )),
            ]
            else if (recents.isNotEmpty) ...[
              if (isPickup && _currentLocation != null)
                _buildSuggestionItem(
                  address: _currentLocationAddress,
                  description: 'Current Location',
                  coordinates: _currentLocation!,
                  isPickup: true,
                  icon: Icons.my_location,
                  iconColor: Colors.blue,
                ),
              _buildSectionHeader('RECENT LOCATIONS'),
              ...recents.take(5).map((item) => _buildSuggestionItem(
                address: item['address'],
                description: item['address'], // Assuming address is stored here
                coordinates: item['location'],
                isPickup: isPickup,
                icon: Icons.history,
                iconColor: Colors.grey.shade600,
              )),
            ]
            else ...[
              if (isPickup && _currentLocation != null)
                 _buildSuggestionItem(
                  address: _currentLocationAddress,
                  description: 'Current Location',
                  coordinates: _currentLocation!,
                  isPickup: true,
                  icon: Icons.my_location,
                  iconColor: Colors.blue,
                ),
              Padding(
                padding: const EdgeInsets.all(32),
                child: Center(
                  child: Column(
                    children: [
                      Icon(Icons.history, size: 48, color: Colors.grey.shade200),
                      const SizedBox(height: 16),
                      Text(
                        'No recent locations',
                        style: TextStyle(
                          color: Colors.grey.shade400,
                          fontWeight: FontWeight.w500,
                        ),
                      ),
                    ],
                  ),
                ),
              ),
            ],
          ],
        ),
      ),
    );
  }

  Widget _buildSectionHeader(String title) {
    return Padding(
      padding: const EdgeInsets.fromLTRB(20, 16, 20, 8),
      child: Text(
        title,
        style: TextStyle(
          fontSize: 11,
          fontWeight: FontWeight.w700,
          color: Colors.grey.shade400,
          letterSpacing: 1.2,
        ),
      ),
    );
  }

  Widget _buildSuggestionItem({
    required String address,
    required String description,
    required LatLng coordinates,
    required bool isPickup,
    required IconData icon,
    required Color iconColor,
  }) {
    // Clean up subtitle if it duplicates the title (description) for display
    String subtitle = address;
    if (subtitle.toLowerCase().startsWith(description.toLowerCase() + ', ')) {
      subtitle = subtitle.substring(description.length + 2);
    }

    return InkWell(
      onTap: () {
        setState(() {
          if (isPickup) {
            _pickupController.text = address; // Keep full address for input
            _pickupLocation = coordinates;
            _pickupAddress = address;
            _showPickupSuggestions = false;
          } else {
            _dropoffController.text = address; // Keep full address for input
            _dropoffLocation = coordinates;
            _dropoffAddress = address;
            _showDestinationSuggestions = false;
            if (_pickupLocation != null) _calculateFareAndETA();
          }
          _searchResults = [];
        });
      },
      child: Container(
        padding: const EdgeInsets.symmetric(horizontal: 20, vertical: 14),
        decoration: BoxDecoration(
          border: Border(
            bottom: BorderSide(color: Colors.grey.shade50, width: 1),
          ),
        ),
        child: Row(
          children: [
            Container(
              padding: const EdgeInsets.all(10),
              decoration: BoxDecoration(
                color: iconColor.withOpacity(0.1),
                shape: BoxShape.circle,
              ),
              child: Icon(icon, size: 20, color: iconColor),
            ),
            const SizedBox(width: 16),
            Expanded(
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  Text(
                    description,
                    style: const TextStyle(
                      fontSize: 15, // Slightly larger
                      fontWeight: FontWeight.w600,
                      color: Color(0xFF1A1A1A),
                    ),
                    maxLines: 1,
                    overflow: TextOverflow.ellipsis,
                  ),
                  if (subtitle.isNotEmpty && subtitle != description)
                    Padding(
                      padding: const EdgeInsets.only(top: 4),
                      child: Text(
                        subtitle,
                        style: TextStyle(
                          fontSize: 13,
                          color: Colors.grey.shade500,
                          height: 1.2,
                        ),
                        maxLines: 1,
                        overflow: TextOverflow.ellipsis,
                      ),
                    ),
                ],
              ),
            ),
            const SizedBox(width: 12),
            Icon(Icons.north_west, size: 16, color: Colors.grey.shade300),
          ],
        ),
      ),
    );
  }

  Widget _buildEmptyState() {
    return Column(
      children: [
        const SizedBox(height: 24),
        // Empty State Message
        Expanded(
          child: Center(
            child: Column(
              mainAxisSize: MainAxisSize.min,
              children: [
                Icon(Icons.directions_car_filled_outlined, 
                     size: 64, 
                     color: Colors.grey.shade300),
                const SizedBox(height: 16),
                Text(
                  'Where to?',
                  style: TextStyle(
                    fontSize: 20,
                    fontWeight: FontWeight.w700,
                    color: Colors.grey.shade400,
                  ),
                ),
              ],
            ),
          ),
        ),
      ],
    );
  }

  Widget _buildFormalRideDetails() {
    if (_isLoadingFare) {
      return Center(
        child: CircularProgressIndicator(
          color: AppTheme.primaryGreen,
          strokeWidth: 2,
        ),
      );
    }

    return Container(
      decoration: BoxDecoration(
        color: Colors.white,
        borderRadius: BorderRadius.circular(20),
        boxShadow: [
          BoxShadow(
            color: Colors.black.withOpacity(0.04),
            blurRadius: 18,
            offset: const Offset(0, 8),
          ),
        ],
      ),
      padding: const EdgeInsets.all(20),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          Row(
            mainAxisAlignment: MainAxisAlignment.spaceBetween,
            crossAxisAlignment: CrossAxisAlignment.end,
            children: [
              Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  Text(
                    'TOTAL FARE',
                    style: TextStyle(
                      fontSize: 11,
                      fontWeight: FontWeight.w600,
                      color: Colors.grey.shade500,
                      letterSpacing: 1,
                    ),
                  ),
                  const SizedBox(height: 4),
                  Text(
                    _estimatedFare != null ? FareService.formatFare(_estimatedFare!) : '₱0',
                    style: const TextStyle(
                      fontSize: 40,
                      fontWeight: FontWeight.w800,
                      color: Color(0xFF1A1A1A),
                      height: 1,
                      letterSpacing: -1.5,
                    ),
                  ),
                ],
              ),
              Container(
                padding: const EdgeInsets.symmetric(horizontal: 10, vertical: 6),
                decoration: BoxDecoration(
                  color: AppTheme.backgroundLight,
                  borderRadius: BorderRadius.circular(20),
                ),
                child: Row(
                  children: [
                    _buildCleanMetric(
                      Icons.near_me_outlined,
                      FareService.formatDistance(_distance ?? 0),
                    ),
                  ],
                ),
              ),
            ],
          ),
          const SizedBox(height: 28),
          Text(
            'PASSENGERS',
            style: TextStyle(
              fontSize: 11,
              fontWeight: FontWeight.w600,
              color: Colors.grey.shade500,
              letterSpacing: 1,
            ),
          ),
          const SizedBox(height: 12),
          Row(
            mainAxisAlignment: MainAxisAlignment.spaceBetween,
            children: List.generate(4, (index) {
              final i = index + 1;
              final isSelected = _passengerCount == i;
              return Expanded(
                child: GestureDetector(
                  onTap: () {
                    setState(() => _passengerCount = i);
                    _calculateFareAndETA();
                  },
                  child: Container(
                    margin: EdgeInsets.only(right: i == 4 ? 0 : 12),
                    height: 48,
                    decoration: BoxDecoration(
                      color: isSelected ? AppTheme.primaryGreen : Colors.white,
                      borderRadius: BorderRadius.circular(12),
                      border: Border.all(
                        color: isSelected ? AppTheme.primaryGreen : Colors.grey.shade200,
                      ),
                    ),
                    child: Center(
                      child: Text(
                        '$i',
                        style: TextStyle(
                          fontSize: 16,
                          fontWeight: FontWeight.w600,
                          color: isSelected ? Colors.white : Colors.grey.shade600,
                        ),
                      ),
                    ),
                  ),
                ),
              );
            }),
          ),
          const SizedBox(height: 28),
          Text(
            'NOTES',
            style: TextStyle(
              fontSize: 11,
              fontWeight: FontWeight.w600,
              color: Colors.grey.shade500,
              letterSpacing: 1,
            ),
          ),
          const SizedBox(height: 12),
          TextField(
            controller: _descriptionController,
            decoration: InputDecoration(
              hintText: 'Any specific instructions?',
              hintStyle: TextStyle(
                fontSize: 14,
                color: Colors.grey.shade400,
              ),
              filled: true,
              fillColor: AppTheme.backgroundLight,
              border: OutlineInputBorder(
                borderRadius: BorderRadius.circular(12),
                borderSide: BorderSide(color: Colors.grey.shade200),
              ),
              enabledBorder: OutlineInputBorder(
                borderRadius: BorderRadius.circular(12),
                borderSide: BorderSide(color: Colors.grey.shade200),
              ),
              focusedBorder: OutlineInputBorder(
                borderRadius: BorderRadius.circular(12),
                borderSide: const BorderSide(color: AppTheme.primaryGreen),
              ),
              contentPadding: const EdgeInsets.all(16),
            ),
            maxLines: 2,
          ),
          const SizedBox(height: 20),
        ],
      ),
    );
  }

  Widget _buildCleanMetric(IconData icon, String value) {
    return Row(
      children: [
        Icon(icon, size: 16, color: Colors.grey.shade500),
        const SizedBox(width: 4),
        Text(
          value,
          style: TextStyle(
            fontSize: 13,
            fontWeight: FontWeight.w600,
            color: Colors.grey.shade700,
          ),
        ),
      ],
    );
  }
}
